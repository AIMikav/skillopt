# SkillOpt Environment Configuration
# Copy this file to .env and fill in your values.

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Provide ONE of the following. SkillOpt checks in this order:
# OPENAI_API_KEY → GEMINI_API_KEY → API_KEY

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
# GEMINI_API_KEY=...

# Generic fallback (any OpenAI-compatible provider)
# API_KEY=...

# ── API Base URL ──────────────────────────────────────────────────────────────
# Override the default OpenAI endpoint for local or alternative providers.

# Ollama (local)
# OPENAI_API_BASE=http://localhost:11434/v1

# Google Gemini via OpenAI-compatible endpoint
# OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/

# Any other OpenAI-compatible endpoint
# OPENAI_API_BASE=https://your-endpoint/v1
